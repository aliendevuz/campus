# --- LOYIHA SOZLAMALARI ---
APP_NAME="Campus"
# MODE: 'development' yoki 'production'
APP_MODE=development
DEBUG=True
# SECRET_KEY: to'liq qiymatni haqiqiy muhitda saqlang (hech qachon versiyaga qo'ymang)
SECRET_KEY=replace-with-your-secret-key

# --- MA'LUMOTLAR BAZASI (POSTGRESQL) ---
# Production rejimida ishlatiladi
DB_USER=postgres
DB_PASSWORD=your_production_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fastapi_db

# --- MA'LUMOTLAR BAZASI (SQLITE) ---
# Development yoki Test rejimida ishlatiladi
SQLITE_URL=sqlite:///./sql_app.db

# --- SERVER SOZLAMALARI ---
HOST=127.0.0.1
PORT=8000

# --- CORS SOZLAMALARI ---
# Agar bir nechta origin bo'lsa, vergul bilan ajrating:
# Misol: "https://app.example.com,https://api.example.com"
BACKEND_CORS_ORIGINS="https://sizning-saytingiz.uz,https://api.sizning-saytingiz.uz"
